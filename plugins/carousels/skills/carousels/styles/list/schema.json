{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "List Carousel",
  "type": "object",
  "required": ["meta", "caption", "hashtags", "slides"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["style", "topic", "count"],
      "properties": {
        "style": { "const": "list" },
        "brand": { "type": "string" },
        "topic": { "type": "string" },
        "count": { "type": "integer", "minimum": 3, "maximum": 15 },
        "generated_at": { "type": "string" }
      }
    },
    "caption": { "type": "string", "minLength": 50, "maxLength": 2200 },
    "hashtags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5,
      "maxItems": 15
    },
    "slides": {
      "type": "array",
      "minItems": 5,
      "maxItems": 17,
      "items": {
        "type": "object",
        "required": ["index", "variant", "titulo", "texto", "destaque"],
        "properties": {
          "index": { "type": "integer" },
          "variant": { "enum": ["minimal", "card", "gradient"] },
          "role": { "enum": ["cover", "item", "outro"] },
          "number": { "type": "integer" },
          "titulo": { "type": "string" },
          "texto": { "type": "string" },
          "destaque": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
