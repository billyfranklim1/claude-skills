{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quote Carousel",
  "type": "object",
  "required": ["meta", "slides"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["style"],
      "properties": {
        "style": { "const": "quote" },
        "brand": { "type": "string" },
        "topic": { "type": "string" },
        "generated_at": { "type": "string" }
      }
    },
    "caption": { "type": "string" },
    "hashtags": { "type": "array", "items": { "type": "string" } },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["index", "variant", "destaque"],
        "properties": {
          "index": { "type": "integer" },
          "variant": { "enum": ["big-text", "with-photo", "minimal"] },
          "role": { "enum": ["quote", "context", "cta"] },
          "quote": { "type": "string" },
          "attribution": { "type": "string" },
          "context": { "type": "string" },
          "titulo": { "type": "string" },
          "texto": { "type": "string" },
          "destaque": { "type": "string" },
          "image_query": { "type": "string" }
        }
      }
    }
  }
}
